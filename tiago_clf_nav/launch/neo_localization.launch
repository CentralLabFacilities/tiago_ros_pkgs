<?xml version="1.0"?>

<launch>

  <!-- Localization Node -->
  <node pkg="neo_localization" type="neo_localization_node" name="neo_localization_node" output="screen">
    <rosparam file="$(find tiago_clf_nav)/config/neo_localization.yaml" command="load" />
	<remap from="scan" to="/scan_clf"/>
  </node>

</launch>